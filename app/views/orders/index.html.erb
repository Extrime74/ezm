<div class="w-full">

  <% if notice.present? %>

    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-lg inline-block" id="notice"><%= notice %></p>

  <% end %>


  <% content_for :title, "Orders" %>


  <div class="flex justify-between items-center mb-10">

    <h1 class="font-bold text-4xl">Заказы</h1>

    <%= link_to "Новый заказ", new_order_path, class: "rounded-lg py-3 px-5 bg-blue-600 text-white block font-medium" %>

  </div>


  <div id="orders" class="flex flex-wrap gap-4">

    <% @orders.each do |order| %>

      <div class="flex-1 p-4 border rounded-lg shadow">

        <%= render partial: "order_short", locals: { order: order } %>

        <p>

          <%= link_to "Show this order", order, class: "ml-2 rounded-lg py-2 px-4 bg-gray-100 inline-block font-medium" %>

        </p>

      </div>

    <% end %>

  </div>

</div>