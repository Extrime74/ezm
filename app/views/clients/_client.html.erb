<div id="<%= dom_id client %>">
  <p class="my-5">
    <strong class="block font-medium mb-1">Имя, Фамилия:</strong>
    <%= client.first_name + ", " + client.last_name%>
  </p>

  <p class="my-5">
    <strong class="block font-medium mb-1">Номер телефона:</strong>
    <%= client.phone_number %>
  </p>

  
  <p class="my-5">
    <strong class="font-medium">Постоянный:</strong> <%= client.loyal_client? ? "✅" : "❌" %>
  </p>

  <p class="my-5">
    <strong class="font-medium">Проблемный:</strong> <%= client.problematic_client? ? "✅" : "❌" %>
  </p>

</div>
